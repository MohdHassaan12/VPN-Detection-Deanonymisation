# ─── VPN Detection & Deanonymisation — Environment Variables ───────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Inference API ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
STAGE1_MODEL_DIR=models/stage1
STAGE2_MODEL_PATH=models/stage2/model.xgb

# JWT secret — change this to a long random string in production!
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32_CHARS_MIN

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Dashboard build arg (used at docker build time) ──────────────────────────
# Set this to your droplet's public IP or domain, e.g. http://165.232.100.200
VITE_API_BASE_URL=http://YOUR_DROPLET_IP
